@page "/owner/{BusinessId:guid}"
@using RealTimeLocationPOC.Web.Models
@using RealTimeLocationPOC.Web.Services.Foundations.LocationUpdates
@using System.Text.Json
@implements IAsyncDisposable
@inject IJSRuntime JS
@inject ILocationUpdateService LocationService
@inject NavigationManager Navigation

<PageTitle>Owner Dashboard</PageTitle>

<div class="dashboard-container">
    <div class="header shadow-md flex justify-between items-center px-8 py-4 bg-white">
        <div class="flex items-center gap-3">
            <span class="text-3xl">📡</span>
            <h1 class="text-xl font-bold text-gray-800">Live Employee Tracker</h1>
        </div>
        <div class="flex gap-4">
            <div class="stat-card">
                <span class="label">Total Employees</span>
                <span class="value">@employees.Count</span>
            </div>
            <div class="stat-card">
                <span class="label">Online</span>
                <span class="value text-green-600">@employees.Values.Count(e => e.IsOnline)</span>
            </div>
        </div>
    </div>

    <div class="map-wrapper">
        <div id="map" class="h-full w-full"></div>
        
        @if (!isMapInitialized)
        {
            <div class="absolute inset-0 flex items-center justify-center bg-gray-100 bg-opacity-75 z-[1000]">
                <div class="loader"></div>
                <p class="ml-4 font-semibold text-gray-600">Initializing Map...</p>
            </div>
        }
    </div>

    <div class="sidebar shadow-2xl overflow-y-auto">
        <h2 class="p-6 text-lg font-bold border-b sticky top-0 bg-white z-10">Employee List</h2>
        <div class="divide-y">
            @foreach (var employee in employees.Values.OrderByDescending(e => e.IsOnline))
            {
                <div class="p-4 hover:bg-gray-50 transition-colors flex items-center justify-between">
                    <div>
                        <p class="font-semibold text-gray-800">@employee.FullName</p>
                        <p class="text-xs text-gray-400">ID: @employee.EmployeeId.ToString().Substring(0, 8)...</p>
                    </div>
                    <div class="flex flex-col items-end">
                        <span class="status-dot @(employee.IsOnline ? "online" : "offline")"></span>
                        <p class="text-[10px] mt-1 text-gray-400">@GetLastSeen(employee)</p>
                    </div>
                </div>
            }
        </div>
    </div>
</div>

<style>
    .dashboard-container {
        display: grid;
        grid-template-columns: 1fr 350px;
        grid-template-rows: auto 1fr;
        height: 100vh;
        font-family: 'Inter', sans-serif;
        overflow: hidden;
    }
    .header {
        grid-column: span 2;
        border-bottom: 1px solid #e5e7eb;
    }
    .map-wrapper {
        position: relative;
        background: #f9fafb;
    }
    .sidebar {
        background: white;
        border-left: 1px solid #e5e7eb;
    }
    .stat-card {
        display: flex;
        flex-direction: column;
        align-items: flex-end;
    }
    .stat-card .label {
        font-size: 10px;
        text-transform: uppercase;
        color: #9ca3af;
        letter-spacing: 0.05em;
    }
    .stat-card .value {
        font-size: 18px;
        font-weight: 700;
    }
    .status-dot {
        width: 10px;
        height: 10px;
        border-radius: 50%;
    }
    .online { background: #10b981; box-shadow: 0 0 8px rgba(16, 185, 129, 0.4); }
    .offline { background: #d1d5db; }
    
    .loader {
        border: 4px solid #f3f4f6;
        border-top: 4px solid #3b82f6;
        border-radius: 50%;
        width: 30px;
        height: 30px;
        animation: spin 1s linear infinite;
    }
    @@keyframes spin { 0% { transform: rotate(0deg); } 100% { transform: rotate(360deg); } }

    /* Leaflet Z-index overrides */
    .leaflet-container { z-index: 1; }
</style>

@code {
    [Parameter] public Guid BusinessId { get; set; }
    private Dictionary<Guid, LocationUpdate> employees = new();
    private bool isMapInitialized = false;

    protected override void OnInitialized()
    {
        LocationService.OnLocationUpdateReceived += HandleLocationUpdate;
    }

    protected override async Task OnAfterRenderAsync(bool firstRender)
    {
        if (firstRender)
        {
            await JS.InvokeVoidAsync("mapInterop.initMap", "map");
            isMapInitialized = true;
            
            await LocationService.StartListeningAsync(BusinessId);
            StateHasChanged();
        }
    }

    private async void HandleLocationUpdate(LocationUpdate location)
    {
        await InvokeAsync(async () => 
        {
            employees[location.EmployeeId] = location;
            
            await JS.InvokeVoidAsync("mapInterop.upsertMarker", 
                location.EmployeeId, 
                location.FullName, 
                location.Latitude, 
                location.Longitude, 
                location.Heading, 
                location.IsOnline);
            
            StateHasChanged();
        });
    }

    private string GetLastSeen(LocationUpdate loc)
    {
        if (loc.IsOnline) return "Just now";
        if (loc.LastSeenAt == DateTimeOffset.MinValue) return "Never";
        return loc.LastSeenAt.ToString("HH:mm:ss");
    }

    public async ValueTask DisposeAsync()
    {
        LocationService.OnLocationUpdateReceived -= HandleLocationUpdate;
        await LocationService.StopListeningAsync(BusinessId);
    }
}
